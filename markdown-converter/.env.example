# Google Cloud
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCS_BUCKET_NAME=pdf-md-converter-temp
GCS_UPLOAD_BUCKET_NAME=
GCS_RESULTS_BUCKET_NAME=

# Mistral OCR
MISTRAL_REGION=us-central1

# Optional: Vertex AI Gemini analysis
VERTEX_AI_LOCATION=us-central1

# Backend
MAX_FILE_SIZE_MB=30
MAX_PAGES_PER_REQUEST=30
JOB_RETENTION_HOURS=24
CORS_ORIGINS_RAW=http://localhost:3001,http://localhost:3000,http://localhost:3002,http://127.0.0.1:3002

# Optional backend service auth for converter API calls
API_KEY=
SERVICE_ACCOUNT_EMAIL=service:api-key

# Google Sign-In auth
GOOGLE_CLIENT_ID=
AUTH_ALLOWED_EMAILS=["bsuccar@changeagents.com.au"]
AUTH_ALLOWED_DOMAINS=["changeagents.com.au"]
SESSION_SECRET=

# Frontend (used only in local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
